---
import ScrollReveal from "./ScrollReveal.tsx";
import { Icon } from "astro-icon/components";
---

<section id="features" class="max-w-6xl mx-auto px-4 py-12 md:py-20">
  <ScrollReveal client:idle delay={0.1}>
    <h2 class="text-4xl font-bold text-gray-900 text-center mb-4">What happens here</h2>
    <p class="text-center text-gray-500 mb-12 max-w-xl mx-auto">
      A home, a workspace, a gathering place — and everything in between.
    </p>
  </ScrollReveal>
  <div class="grid md:grid-cols-2 gap-8">
    <ScrollReveal client:idle delay={0.2} scale={true}>
      <div class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:home" class="w-6 h-6 text-gray-900" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Stay</h3>
        <p class="text-gray-600">
          Overnight accommodation for contributors visiting Barcelona — a home, not a hotel.
          The house runs on donations: guests contribute what they can through the Giveth
          platform after their stay.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.3} scale={true}>
      <div class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:desk" class="w-6 h-6 text-gray-900" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Cowork</h3>
        <p class="text-gray-600">
          A shared workspace open to builders, researchers, and contributors from across
          the Ethereum and broader blockchain4good ecosystem — a place to focus and work
          alongside people building aligned projects.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.4} scale={true}>
      <div class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:users" class="w-6 h-6 text-gray-900" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Gather</h3>
        <p class="text-gray-600">
          Talks, workshops, hacker houses, unconferences, and community dinners — the house
          is a recurring venue for teams and communities across the Web3 ecosystem looking
          for an intimate, value-aligned space to meet and build together.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.5} scale={true}>
      <div class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
          <Icon name="tabler:heart-handshake" class="w-6 h-6 text-gray-900" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Connect</h3>
        <p class="text-gray-600">
          The real value of Giveth House is the people. Over 500 visitors from across
          the Web3 world have passed through — friendships, collaborations, and projects
          that started here and kept growing long after people left.
        </p>
      </div>
    </ScrollReveal>
  </div>
</section>
