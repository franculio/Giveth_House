---
import ScrollReveal from "./ScrollReveal.tsx";
import { Icon } from "astro-icon/components";
---

<section id="features" class="max-w-6xl mx-auto px-4 py-20">
  <ScrollReveal client:idle delay={0.1}>
    <h2 class="text-4xl font-bold text-gray-900 text-center mb-12">At Giveth House</h2>
  </ScrollReveal>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
    <ScrollReveal client:idle delay={0.2} scale={true}>
      <div
        class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow"
      >
        <div
          class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4"
        >
          <Icon name="tabler:desk" class="w-6 h-6 text-gray-900" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Coworking</h3>
        <p class="text-gray-600">
          A shared workspace for builders, researchers, and contributors to ship together — and
          meet the broader Barcelona Web3 community.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.3} scale={true}>
      <div
        class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow"
      >
        <div
          class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4"
        >
          <Icon
            name="tabler:bolt"
            class="w-6 h-6 text-gray-900"
            aria-hidden="true"
          />
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Hacker Houses</h3>
        <p class="text-gray-600">
          Temporary hacker houses around ecosystem moments — a home base for teams building during
          conferences and community gatherings.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.4} scale={true}>
      <div
        class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow"
      >
        <div
          class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4"
        >
          <Icon name="tabler:users" class="w-6 h-6 text-gray-900" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Community Events</h3>
        <p class="text-gray-600">
          Talks, workshops, meetups, and informal gatherings — bringing communities together in a
          physical Schelling point.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.5} scale={true}>
      <div
        class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow"
      >
        <div
          class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4"
        >
          <Icon name="tabler:git-merge" class="w-6 h-6 text-gray-900" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Collaboration Sessions</h3>
        <p class="text-gray-600">
          Work sessions for open source and Web3 infrastructure — pairing, sharing context, and
          helping each other unblock.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.6} scale={true}>
      <div
        class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow"
      >
        <div
          class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4"
        >
          <Icon name="tabler:home" class="w-6 h-6 text-gray-900" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Community Living</h3>
        <p class="text-gray-600">
          A welcoming place to stay for contributors visiting Barcelona — built for shared meals,
          conversations, and lasting relationships.
        </p>
      </div>
    </ScrollReveal>
    <ScrollReveal client:idle delay={0.7} scale={true}>
      <div class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow">
        <div
          class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4"
        >
          <Icon name="tabler:heart-handshake" class="w-6 h-6 text-gray-900" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Community Stewardship</h3>
        <p class="text-gray-600">
          A community-driven space supported by donors and stewards — keeping the house running so
          builders and communities can keep showing up.
        </p>
      </div>
    </ScrollReveal>
  </div>
</section>
