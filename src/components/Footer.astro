---
import { Icon } from "astro-icon/components";
---

<footer
  id="contact"
  class="w-full py-12 px-4 border-t border-gray-200 bg-white"
  role="contentinfo"
>
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Giveth House</h2>
        <p class="text-gray-600">
          A community-driven Web3 hub in Barcelona (Sants) — a shared home,
          coworking space, and gathering place for builders and communities.
        </p>
      </div>
      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Links</h2>
        <ul class="space-y-2">
          <li>
            <a href="/about" class="text-gray-600 hover:text-gray-900 transition-colors">About</a>
          </li>
          <li>
            <a href="/visit" class="text-gray-600 hover:text-gray-900 transition-colors">Visit</a>
          </li>
          <li>
            <a href="/faqs" class="text-gray-600 hover:text-gray-900 transition-colors">FAQs</a>
          </li>
          <li>
            <a href="/support" class="text-gray-600 hover:text-gray-900 transition-colors">Support</a>
          </li>
          <li>
            <a href="/contact" class="text-gray-600 hover:text-gray-900 transition-colors">Contact</a>
          </li>
        </ul>
      </div>
      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Connect</h2>
        <ul class="space-y-2">
          <li>
            <a
              href="https://x.com/GivethHouse"
              class="flex items-center gap-2 text-gray-600 hover:text-gray-900 transition-colors"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Follow Giveth House on X (opens in new tab)"
            >
              <Icon name="tabler:brand-x" class="w-5 h-5" aria-hidden="true" />
              <span>X</span>
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class="flex items-center gap-2 text-gray-600 hover:text-gray-900 transition-colors"
            >
              <Icon name="tabler:mail" class="w-5 h-5" aria-hidden="true" />
              <span>Email</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="pt-8 border-t border-gray-200 text-center text-gray-600">
      <p>&copy; {new Date().getFullYear()} Giveth House. All rights reserved.</p>
    </div>
  </div>
</footer>
