---
import ScrollReveal from "./ScrollReveal.tsx";
---

<section class="border-y border-gray-100 bg-gray-50">
  <ScrollReveal client:idle delay={0.1}>
    <div class="max-w-6xl mx-auto px-4 py-10 grid grid-cols-3 gap-4 text-center">
      <div>
        <p class="text-4xl font-bold text-gray-900">500+</p>
        <p class="text-sm text-gray-500 mt-1">visitors from the Web3 ecosystem</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-gray-900">7,500+</p>
        <p class="text-sm text-gray-500 mt-1">guest-nights hosted</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-gray-900">7+</p>
        <p class="text-sm text-gray-500 mt-1">years open in Barcelona</p>
      </div>
    </div>
  </ScrollReveal>
</section>
