---
import ScrollReveal from "./ScrollReveal.tsx";
---

<section class="border-y border-gray-100 bg-gray-50">
  <ScrollReveal client:idle delay={0.1}>
    <div class="max-w-6xl mx-auto px-4 py-8 grid grid-cols-3 gap-2 text-center">
      <div>
        <p class="text-2xl md:text-4xl font-bold text-gray-900">500+</p>
        <p class="text-xs md:text-sm text-gray-500 mt-1">visitors from Web3</p>
      </div>
      <div>
        <p class="text-2xl md:text-4xl font-bold text-gray-900">7,500+</p>
        <p class="text-xs md:text-sm text-gray-500 mt-1">guest-nights hosted</p>
      </div>
      <div>
        <p class="text-2xl md:text-4xl font-bold text-gray-900">9+</p>
        <p class="text-xs md:text-sm text-gray-500 mt-1">years in Barcelona</p>
      </div>
    </div>
  </ScrollReveal>
</section>
