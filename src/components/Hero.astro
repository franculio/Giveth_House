---
import ScrollReveal from "./ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";
---

<section class="max-w-6xl mx-auto px-4 py-20 md:py-32 text-center" aria-labelledby="hero-heading">
  <ScrollReveal client:load>
    <h1 id="hero-heading" class="text-5xl md:text-6xl font-bold text-gray-900 mb-6">
      A Home for Web3 Builders and Communities
    </h1>
  </ScrollReveal>
  <ScrollReveal client:load delay={0.2}>
    <p class="text-xl md:text-2xl text-gray-600 mb-8 max-w-2xl mx-auto">
      The physical home of the Giveth Galaxy in Barcelona's Sants neighbourhood —
      a shared living space, coworking hub, and gathering point for the
      blockchain4good community, open since 2017.
    </p>
  </ScrollReveal>
  <ScrollReveal client:load delay={0.4}>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={SITE.telegramBot}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3 bg-black text-white rounded-lg hover:bg-gray-800 transition-colors font-medium"
        aria-label="Apply via Telegram bot"
      >
        <span>Apply via Telegram</span>
      </a>
      <a
        href="/visit"
        class="inline-block px-8 py-3 bg-white text-gray-900 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors font-medium"
      >
        How it Works
      </a>
    </div>
  </ScrollReveal>
</section>
