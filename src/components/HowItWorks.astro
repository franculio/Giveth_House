---
import ScrollReveal from "./ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";
---

<section class="max-w-6xl mx-auto px-4 py-20 border-t border-gray-100">
  <ScrollReveal client:idle delay={0.1}>
    <h2 class="text-4xl font-bold text-gray-900 text-center mb-4">How it Works</h2>
    <p class="text-center text-gray-500 mb-14 max-w-xl mx-auto">
      No booking fees, no fixed prices. Just a short application via Telegram.
    </p>
  </ScrollReveal>

  <div class="grid md:grid-cols-3 gap-8">
    <ScrollReveal client:idle delay={0.2} scale={true}>
      <div class="text-center">
        <div class="w-12 h-12 rounded-full bg-black text-white flex items-center justify-center text-xl font-bold mx-auto mb-4">1</div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Apply via Telegram</h3>
        <p class="text-gray-600 text-sm">
          Open <a href={SITE.telegramBot} target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-900">{SITE.telegramHandle}</a>
          {" "}and fill in the short intake form — type of visit, dates, and a bit about yourself.
        </p>
      </div>
    </ScrollReveal>

    <ScrollReveal client:idle delay={0.3} scale={true}>
      <div class="text-center">
        <div class="w-12 h-12 rounded-full bg-black text-white flex items-center justify-center text-xl font-bold mx-auto mb-4">2</div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Get approved</h3>
        <p class="text-gray-600 text-sm">
          Franco reviews every request personally and replies via Telegram.
          Approvals are based on availability and alignment with the space.
        </p>
      </div>
    </ScrollReveal>

    <ScrollReveal client:idle delay={0.4} scale={true}>
      <div class="text-center">
        <div class="w-12 h-12 rounded-full bg-black text-white flex items-center justify-center text-xl font-bold mx-auto mb-4">3</div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Stay & contribute</h3>
        <p class="text-gray-600 text-sm">
          Show up, connect with the community, and give back through the{" "}
          <a href={SITE.givethDonation} target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-900">Giveth platform</a>
          {" "}— whatever feels right for you.
        </p>
      </div>
    </ScrollReveal>
  </div>
</section>
