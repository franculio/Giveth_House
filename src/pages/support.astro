---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";

type Campaign = {
  name: string;
  description: string;
  url: string;
  cta: string;
};

const campaigns: Campaign[] = [
  {
    name: "Giveth",
    description:
      "Support the house directly through the Giveth platform. Donate in almost any crypto token on most major chains — 100% of donations go to the project.",
    url: SITE.givethDonation,
    cta: "Donate on Giveth",
  },
  {
    name: "CrowdWalrus",
    description:
      "Contribute through the CrowdWalrus campaign and help keep the house running as a free, open resource for the Web3 community.",
    url: "https://crowdwalrus.xyz/campaigns/givethouse",
    cta: "Support on CrowdWalrus",
  },
];
---

<Layout
  title={`Support | ${SITE.title}`}
  description="Support Giveth House — the IRL solarpunk nexus for the blockchain4good community in Barcelona. Your donations keep the doors open."
  canonicalURL={`${SITE.url}/support`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-4xl mx-auto px-4 py-12 md:py-20">

      <ScrollReveal client:idle>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Support Giveth House</h1>
      </ScrollReveal>

      <ScrollReveal client:load delay={0.1}>
        <p class="text-xl text-gray-600 mb-10 max-w-2xl">
          Giveth House is a gift economy space sustained entirely by community generosity.
          No ticket sales, no membership fees — just people who believe a physical
          Schelling point for the blockchain4good ecosystem is worth keeping alive.
        </p>
      </ScrollReveal>

      <!-- What your support makes possible -->
      <ScrollReveal client:load delay={0.2}>
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 mb-10">
          <h2 class="text-lg font-semibold text-gray-900 mb-3">What your support makes possible</h2>
          <p class="text-gray-600 mb-4">
            Since 2017, Giveth House has hosted over <strong>500 visitors</strong> from across the
            Web3 ecosystem — builders from Ethereum Foundation, Arbitrum, Starknet, Dappnode,
            General Magic, Vocdoni, Fuel Labs, Blobscan, Gitcoin, and many more. The house has
            been the backdrop for hacker houses, workshops, unconferences, community dinners,
            and countless collaborations that started over a shared meal and turned into real projects.
          </p>
          <p class="text-gray-600">
            Your donations cover the practical realities that keep those doors open:
            rent, utilities, maintenance, and the operations that make Giveth House a warm,
            welcoming, and functional home for the community.
          </p>
        </div>
      </ScrollReveal>

      <!-- Donation platforms -->
      <ScrollReveal client:load delay={0.3}>
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Donate</h2>
      </ScrollReveal>

      <div class="grid gap-6 md:grid-cols-2 mb-12">
        {campaigns.map((campaign, index) => (
          <ScrollReveal client:load delay={0.35 + index * 0.1}>
            <article class="bg-white rounded-lg border border-gray-200 p-6 shadow-sm flex flex-col justify-between h-full">
              <div>
                <h3 class="text-2xl font-semibold text-gray-900 mb-2">
                  {campaign.name}
                </h3>
                <p class="text-gray-600 mb-4">
                  {campaign.description}
                </p>
              </div>
              <div>
                <a
                  href={campaign.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center px-5 py-2.5 bg-black text-white rounded-lg hover:bg-gray-800 transition-colors text-sm font-medium"
                >
                  {campaign.cta}
                </a>
              </div>
            </article>
          </ScrollReveal>
        ))}
      </div>

      <!-- Gift economy note -->
      <ScrollReveal client:load delay={0.5}>
        <div class="border-t border-gray-100 pt-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">If you've stayed here</h2>
          <p class="text-gray-600 mb-4">
            Giveth House runs on a gift economy model — there is no fixed price for staying.
            If you have benefited from being here, please consider giving back through one of
            the donation platforms above.
          </p>
          <p class="text-gray-600">
            The long-term vision is for the house to remain a free, open resource for the
            Web3 ecosystem — a place where the values behind the code become real,
            and where the next generation of builders finds community, collaboration,
            and a warm place to land in Barcelona.
          </p>
        </div>
      </ScrollReveal>

      <!-- Community Supporter -->
      <ScrollReveal client:load delay={0.6}>
        <div class="border-t border-gray-100 pt-10 mt-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Community Supporter</h2>
          <p class="text-gray-600 mb-4">
            If you use the space regularly and want to contribute in a more structured way,
            we're developing a voluntary Community Supporter program — for individuals and
            teams who believe in what this space represents and want to help keep it running
            long-term.
          </p>
          <p class="text-gray-600 mb-6">
            No fixed tiers, no public pricing. If this resonates with you, reach out and
            we can talk about what makes sense.
          </p>
          <a
            href={SITE.telegramBot}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-5 py-2.5 bg-black text-white rounded-lg hover:bg-gray-800 transition-colors text-sm font-medium"
          >
            Get in touch via Telegram
          </a>
        </div>
      </ScrollReveal>

    </section>
  </main>
  <Footer />
</Layout>
