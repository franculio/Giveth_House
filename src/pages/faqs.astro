---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";

const faqs = [
  {
    question: "What is Giveth House?",
    answer:
      "Giveth House is a community home in Barcelona's Sants neighborhood — a shared living space, coworking hub, and gathering place for builders and communities working across the Web3 and ReFi ecosystem. It's been open since 2017 and has hosted contributors connected to projects like Ethereum Foundation, Arbitrum, Starknet, Dappnode, and many others.",
  },
  {
    question: "How much does it cost to stay?",
    answer:
      "There is no fixed price. Giveth House runs on a gift economy model — guests are invited to contribute what feels right through the Giveth donation platform after their stay. You can donate in almost any crypto token on most major chains. The house is sustained entirely by community generosity.",
  },
  {
    question: "How do I apply for a stay, coworking day, or visit?",
    answer:
      "Everything starts with the Telegram bot (@GivethHousy_bot). Open it and complete the short intake form — choose your type of visit, share your dates, tell us a bit about yourself, and mention your connection to the community. Franco reviews every request personally and replies via Telegram.",
  },
  {
    question: "Who is it for?",
    answer:
      "The house is primarily for open source contributors, DAO builders, Ethereum ecosystem participants, and Web3 communities visiting Barcelona. That said, the door is open to anyone genuinely aligned with the values of the space — curiosity, collaboration, and building better systems. A community vouch is appreciated but not required.",
  },
  {
    question: "What if I don't have a community vouch?",
    answer:
      "A vouch helps but it's not a hard requirement. If you're aligned with the values of the space and can share a bit about what you're working on, Franco will consider your request. The intake form asks about your connection to the community — just be honest and genuine.",
  },
  {
    question: "Can I host an event?",
    answer:
      "Yes. Giveth House regularly hosts small talks, workshops, hacker houses, community dinners, and informal meetups. The basement and common areas work well for intimate gatherings and collaborative sessions. Apply via the Telegram bot and mention you'd like to host an event.",
  },
  {
    question: "How is Giveth House funded?",
    answer:
      "The house is supported through community donations on the Giveth platform and CrowdWalrus. Contributions help cover rent, utilities, maintenance, and operations so the space can remain open as a shared resource for the Web3 ecosystem. Every contribution, large or small, makes a difference.",
  },
];
---

<Layout
  title={`FAQs | ${SITE.title}`}
  description="Frequently asked questions about Giveth House — who it's for, how stays work, events, and how the house is funded."
  canonicalURL={`${SITE.url}/faqs`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-6xl mx-auto px-4 py-20">
      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold text-gray-900 mb-4">FAQs</h1>
      </ScrollReveal>

      <ScrollReveal client:load delay={0.1}>
        <p class="text-xl text-gray-600 mb-12 max-w-2xl">
          Learn more about what Giveth House is, who it's for, and how you can
          visit, stay, or support the space.
        </p>
      </ScrollReveal>

      <ScrollReveal client:load delay={0.2}>
        <div class="space-y-3" role="list">
          {faqs.map((faq) => (
            <details
              class="faq-accordion group bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden"
            >
              <summary class="flex items-center justify-between gap-4 list-none cursor-pointer px-6 py-4 text-left font-semibold text-gray-900 hover:bg-gray-50 transition-colors [&::-webkit-details-marker]:hidden">
                <span>{faq.question}</span>
                <span
                  class="shrink-0 w-6 h-6 flex items-center justify-center text-gray-400 group-open:rotate-180 transition-transform"
                  aria-hidden="true"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-4 pt-0 border-t border-gray-100">
                <p class="text-gray-600 pt-3">{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </ScrollReveal>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .faq-accordion summary::-webkit-details-marker {
    display: none;
  }
</style>